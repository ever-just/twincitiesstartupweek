<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- CRM Lead Form View Enhancement -->
        <record id="view_crm_lead_form_tcsw" model="ir.ui.view">
            <field name="name">crm.lead.form.tcsw</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_case_form_view_oppor"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='planned_revenue']" position="after">
                    <group string="Sponsor/Vendor Classification">
                        <field name="is_sponsor"/>
                        <field name="is_vendor"/>
                        <field name="sponsor_tier" attrs="{'invisible': [('is_sponsor', '=', False)]}"/>
                        <field name="sponsorship_amount" attrs="{'invisible': [('is_sponsor', '=', False)]}"/>
                        <field name="deliverables_count"/>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- Partner Form View Enhancement -->
        <record id="view_partner_form_tcsw" model="ir.ui.view">
            <field name="name">res.partner.form.tcsw</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='email']" position="after">
                    <field name="is_organization"/>
                    <field name="event_partner_count"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
