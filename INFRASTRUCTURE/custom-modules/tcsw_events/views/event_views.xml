<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Event Form View Enhancement -->
        <record id="view_event_form_tcsw" model="ir.ui.view">
            <field name="name">event.event.form.tcsw</field>
            <field name="model">event.event</field>
            <field name="inherit_id" ref="event.view_event_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="is_startup_week"/>
                    <field name="partner_org_count"/>
                    <field name="venue_count"/>
                </xpath>
            </field>
        </record>

        <!-- Registration Form View Enhancement -->
        <record id="view_event_registration_form_tcsw" model="ir.ui.view">
            <field name="name">event.registration.form.tcsw</field>
            <field name="model">event.registration</field>
            <field name="inherit_id" ref="event.view_event_registration_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <group string="Volunteer Information">
                        <field name="is_volunteer"/>
                        <field name="volunteer_role" attrs="{'invisible': [('is_volunteer', '=', False)]}"/>
                        <field name="volunteer_shifts" attrs="{'invisible': [('is_volunteer', '=', False)]}"/>
                    </group>
                    <group string="Sponsor Information">
                        <field name="sponsor_tier"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
